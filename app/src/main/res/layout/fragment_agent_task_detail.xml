<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_section_header"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/agent_detail_back"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="返回主页"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="40dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text=""
            app:icon="@drawable/ic_arrow_back_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/app_primary" />

        <TextView
            android:id="@+id/agent_detail_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="AgentServer 任务" />

        <TextView
            android:id="@+id/agent_detail_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_chip"
            android:textColor="@color/app_text_secondary"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="12dp" />

    </LinearLayout>

    <!-- 对话气泡列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/agent_detail_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/app_bg_secondary"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:clipToPadding="false" />

</LinearLayout>
