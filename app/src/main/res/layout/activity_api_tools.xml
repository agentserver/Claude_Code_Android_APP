<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_secondary"
    android:orientation="vertical">

    <include
        android:id="@+id/partial_primary_toolbar"
        layout="@layout/partial_primary_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_bg_secondary"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/api_tools_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/api_tools_description"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/api_tools_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/api_tools_status_ready"
                android:textColor="@color/app_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_api_battery"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/app_primary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/api_tools_button_battery"
                android:textColor="@color/app_on_primary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_api_camera"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/api_tools_button_camera"
                android:textColor="@color/app_primary"
                android:textSize="13sp"
                app:strokeColor="@color/app_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_api_sensor"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/api_tools_button_sensor"
                android:textColor="@color/app_primary"
                android:textSize="13sp"
                app:strokeColor="@color/app_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_api_wifi"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/api_tools_button_wifi"
                android:textColor="@color/app_primary"
                android:textSize="13sp"
                app:strokeColor="@color/app_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_api_clipboard"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/api_tools_button_clipboard"
                android:textColor="@color/app_primary"
                android:textSize="13sp"
                app:strokeColor="@color/app_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_api_clear"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/api_tools_button_clear"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                app:strokeColor="@color/app_border" />

            <TextView
                android:id="@+id/api_tools_output_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/api_tools_output_label"
                android:textColor="@color/app_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/api_tools_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_settings_preference_item"
                android:minHeight="120dp"
                android:padding="12dp"
                android:text="@string/api_tools_output_hint"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                android:textIsSelectable="true"
                android:typeface="monospace" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
