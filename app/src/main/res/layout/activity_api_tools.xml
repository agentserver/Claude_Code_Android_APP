<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_secondary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="14dp"
        android:paddingEnd="12dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/api_tools_header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/api_tools_back_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="返回设置"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="40dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text=""
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/app_primary" />

            <TextView
                android:id="@+id/api_tools_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/title_activity_api_tools"
                android:textColor="@color/app_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/api_tools_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:text="@string/api_tools_description"
            android:textColor="@color/app_text_muted"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_section_header"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="状态"
            android:textColor="@color/app_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/app_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/app_border"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/api_tools_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp"
                android:text="@string/api_tools_status_ready"
                android:textColor="@color/app_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_section_header"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="能力"
            android:textColor="@color/app_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/app_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/app_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_api_battery"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:backgroundTint="@color/app_primary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/api_tools_button_battery"
                    android:textColor="@color/app_on_primary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_api_camera"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/api_tools_button_camera"
                        android:textColor="@color/app_primary"
                        android:textSize="13sp"
                        app:strokeColor="@color/app_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_api_sensor"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/api_tools_button_sensor"
                        android:textColor="@color/app_primary"
                        android:textSize="13sp"
                        app:strokeColor="@color/app_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_api_wifi"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/api_tools_button_wifi"
                        android:textColor="@color/app_primary"
                        android:textSize="13sp"
                        app:strokeColor="@color/app_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_api_clipboard"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/api_tools_button_clipboard"
                        android:textColor="@color/app_primary"
                        android:textSize="13sp"
                        app:strokeColor="@color/app_primary" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_api_clear"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/api_tools_button_clear"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="13sp"
                    app:strokeColor="@color/app_border" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/api_tools_output_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_section_header"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="@string/api_tools_output_label"
            android:textColor="@color/app_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/api_tools_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_settings_preference_item"
            android:minHeight="150dp"
            android:padding="14dp"
            android:text="@string/api_tools_output_hint"
            android:textColor="@color/app_text_secondary"
            android:textIsSelectable="true"
            android:textSize="13sp"
            android:typeface="monospace" />
    </LinearLayout>
</ScrollView>
