<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AgentServer 首次连接需要授权"
        android:textColor="#212121"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="用手机相机扫码，或复制下方链接到浏览器打开，完成授权后此弹窗会自动关闭。"
        android:textColor="#666666"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:id="@+id/auth_qr_image"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:background="#FFFFFF"
        android:contentDescription="授权二维码"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/auth_url_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#1976D2"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:background="#F0F0F0"
        android:padding="10dp"
        android:textIsSelectable="true"
        android:layout_marginBottom="12dp"
        android:maxLines="3"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/auth_btn_copy"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="复制链接"
            android:textSize="13sp"
            android:layout_marginEnd="6dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/auth_btn_open"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="浏览器打开"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#1976D2"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

</LinearLayout>
