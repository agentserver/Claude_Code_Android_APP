<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Accent left bar -->
    <item android:width="4dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="@color/app_bubble_tool_accent" />
            <corners android:topLeftRadius="10dp" android:bottomLeftRadius="10dp" />
        </shape>
    </item>
    <!-- Main background -->
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/app_bubble_tool" />
            <corners android:topRightRadius="10dp" android:bottomRightRadius="10dp" />
        </shape>
    </item>
</layer-list>
